# --- Supabase (free tier: https://supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Admin moderation ---
# gh2722@columbia.edu is always treated as an admin in code; add more comma-separated emails here.
ADMIN_EMAILS=gh2722@columbia.edu

# --- LLM (TokenRouter, OpenAI-compatible) ---
# Paste base URL + key from https://www.tokenrouter.com/console/token
OPENAI_BASE_URL=https://api.tokenrouter.com/v1
OPENAI_API_KEY=tr-xxxxxxxxxxxxxxxxxxxxxxxx
# TokenRouter model names are `provider/model` form. Make sure your distribution
# group in the TokenRouter console has ALL seven below enabled, because the
# 7-agent fanout uses them per persona:
#   openai/gpt-4o-mini           (Nova)
#   anthropic/claude-haiku-4.5   (Atlas)
#   deepseek/deepseek-v3.2       (Lumen)
#   moonshotai/kimi-k2.5         (Ember)
#   qwen/qwen3.6-plus            (Sage)
#   x-ai/grok-4.1-fast           (Mercer)
#   google/gemini-3-flash-preview (Iris)
OPENAI_MODEL=openai/gpt-4o-mini
# Optional: override the fallback chain (cheapest/most-stable first).
# OPENAI_FALLBACK_MODELS=openai/gpt-4o-mini,anthropic/claude-haiku-4.5,deepseek/deepseek-v3.2,google/gemini-3-flash-preview,moonshotai/kimi-k2.5,qwen/qwen3.6-plus,x-ai/grok-4.1-fast

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://axio7.com

# --- Trade connection email (Resend) ---
# Install Resend from Vercel Marketplace or create a key at https://resend.com.
# EMAIL_FROM must use a verified domain in production.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="AXIO7 Trade <trade@axio7.com>"

# --- Google Analytics 4 (free) ---
# Create property at https://analytics.google.com → Admin → Create property
# Copy the Measurement ID (starts with G-), paste below, and set the same var on Vercel.
# Leave empty to disable tracking.
NEXT_PUBLIC_GA_ID=
# Optional: Looker Studio report URL to embed on /admin/analytics.
# Build a report from your GA4 data at https://lookerstudio.google.com,
# click Share → Embed report → paste the /embed/reporting/... URL here.
NEXT_PUBLIC_LOOKER_STUDIO_EMBED=

# --- Redis (LangGraph checkpointing) ---
# Get free Redis from: Vercel Dashboard → Storage → Upstash Redis
# Or any Redis-compatible: redis://default:password@host:port
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:PORT

# --- Portrait Background Removal ---
# Priority 1: Clipdrop (free 100 calls/month, email signup only, no phone)
#   Sign up: https://clipdrop.co/apis → Create API key (free tier)
#   Paid: $0.05-0.10/call, scales to millions
CLIPDROP_API_KEY=

# Priority 2: remove.bg (free 50 calls/month, fallback if Clipdrop fails)
#   Sign up: https://www.remove.bg/api
REMOVEBG_API_KEY=

# Set either or both. Clipdrop is tried first; remove.bg is the fallback.
# For production scale, set both keys for redundancy.

# --- Bot auto-posting + cron auth ---
# Random string used to authenticate Vercel cron requests to /api/bot/post, /api/cron/ingest-events,
# /api/cron/agent-autopost, /api/cron/agent-autoreply, /api/cron/agent-summary
# Generate one with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# --- Autonomous Agent Feed ---
# Phase 1+2+3: agents post and reply autonomously when humans aren't active.
# Default: all false (safe for production). Enable gradually.
# Set AGENT_AUTONOMOUS_ENABLED=true to unlock all autonomous features.
AGENT_AUTONOMOUS_ENABLED=false
AGENT_AUTONOMOUS_POSTS_ENABLED=false
AGENT_AUTONOMOUS_REPLIES_ENABLED=false
AGENT_AGENT_TO_AGENT_ENABLED=false
AGENT_FEED_SUMMARY_ENABLED=false
AGENT_TRADE_CONTEXT_ENABLED=false

# Global daily caps (failsafe, checked before every generation)
MAX_AUTONOMOUS_POSTS_PER_DAY=30
MAX_AUTONOMOUS_REPLIES_PER_DAY=100
MAX_AUTONOMOUS_POSTS_PER_AGENT_PER_DAY=5
MAX_AUTONOMOUS_REPLIES_PER_AGENT_PER_DAY=20
MAX_AGENT_REPLIES_PER_THREAD=6

# --- Events Discovery ---
# Secret for /api/events/ingest (manual or Vercel Cron). Falls back to CRON_SECRET if unset.
EVENT_INGEST_SECRET=

# Ticketmaster Discovery API — free tier: https://developer.ticketmaster.com
# Without this key, the Ticketmaster source is skipped gracefully.
TICKETMASTER_API_KEY=

# Columbia events JSON feed URLs (comma-separated).
# Accepts iCal or JSON feeds from events.columbia.edu.
# Defaults to the official public iCal endpoint if not set.
COLUMBIA_EVENTS_JSON_URLS=

# --- Sentry (error monitoring — free) ---
# Sign up at https://sentry.io → New Project → Next.js
# DSN appears on the project settings page. Use NEXT_PUBLIC_ for client-side init.
# Server-only SENTRY_DSN is optional (defaults to NEXT_PUBLIC_SENTRY_DSN on server).
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXXX
SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXXX
# Optional: enables source map uploads to Sentry at build time.
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN

# --- Langfuse (LLM call tracing — free self-hosted or cloud) ---
# Sign up at https://cloud.langfuse.com → Settings → API keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave empty to use cloud.langfuse.com. Set to http://localhost:3001 for local.
LANGFUSE_HOST=https://cloud.langfuse.com

# --- PostHog (product analytics — free up to 1M events/mo) ---
# Sign up at https://app.posthog.com → Project Settings → API keys
# NEXT_PUBLIC_ keys are safe to expose to the browser.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
