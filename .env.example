# --- Supabase (free tier: https://supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- LLM (TokenRouter, OpenAI-compatible) ---
# Paste base URL + key from https://www.tokenrouter.com/console/token
OPENAI_BASE_URL=https://api.tokenrouter.com/v1
OPENAI_API_KEY=tr-xxxxxxxxxxxxxxxxxxxxxxxx
# TokenRouter model names are `provider/model` form. Make sure your distribution
# group in the TokenRouter console has ALL three below enabled, because the
# 7-agent fanout uses them per persona:
#   openai/gpt-4o-mini          (Nova, Ember, Mercer)
#   anthropic/claude-haiku-4.5  (Atlas, Lumen)
#   qwen/qwen3.6-plus           (Sage, Iris)
OPENAI_MODEL=openai/gpt-4o-mini
# Optional: override the fallback chain used when a model 503s.
# OPENAI_FALLBACK_MODELS=openai/gpt-4o-mini,anthropic/claude-haiku-4.5,qwen/qwen3.6-plus

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
