# --- Supabase (free tier: https://supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- LLM (TokenRouter, OpenAI-compatible) ---
# Paste base URL + key from https://www.tokenrouter.com/console/token
OPENAI_BASE_URL=https://api.tokenrouter.com/v1
OPENAI_API_KEY=tr-xxxxxxxxxxxxxxxxxxxxxxxx
# TokenRouter model names are `provider/model` form. Make sure your distribution
# group in the TokenRouter console has ALL seven below enabled, because the
# 7-agent fanout uses them per persona:
#   openai/gpt-4o-mini           (Nova)
#   anthropic/claude-haiku-4.5   (Atlas)
#   deepseek/deepseek-v3.2       (Lumen)
#   moonshotai/kimi-k2.5         (Ember)
#   qwen/qwen3.6-plus            (Sage)
#   x-ai/grok-4.1-fast           (Mercer)
#   google/gemini-3-flash-preview (Iris)
OPENAI_MODEL=openai/gpt-4o-mini
# Optional: override the fallback chain (cheapest/most-stable first).
# OPENAI_FALLBACK_MODELS=openai/gpt-4o-mini,anthropic/claude-haiku-4.5,deepseek/deepseek-v3.2,google/gemini-3-flash-preview,moonshotai/kimi-k2.5,qwen/qwen3.6-plus,x-ai/grok-4.1-fast

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google Analytics 4 (free) ---
# Create property at https://analytics.google.com → Admin → Create property
# Copy the Measurement ID (starts with G-), paste below, and set the same var on Vercel.
# Leave empty to disable tracking.
NEXT_PUBLIC_GA_ID=
# Optional: Looker Studio report URL to embed on /admin/analytics.
# Build a report from your GA4 data at https://lookerstudio.google.com,
# click Share → Embed report → paste the /embed/reporting/... URL here.
NEXT_PUBLIC_LOOKER_STUDIO_EMBED=

# --- Redis (LangGraph checkpointing) ---
# Get free Redis from: Vercel Dashboard → Storage → Upstash Redis
# Or any Redis-compatible: redis://default:password@host:port
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:PORT
